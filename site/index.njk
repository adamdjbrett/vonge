---
layout: layouts/base.njk
title: Vonge
---
{% from "components.njk" import blogCard, projectCard, testimonialCard, newsletter %}

<section class="c-hero animate">
  <div class="container">
    <div class="row">
      <div class="col col-12">
        <div class="c-hero__inner">
          <div class="c-hero__left">
            <h1 class="c-hero__title">{{ site.homepage.hero.title }}</h1>
            <div class="c-hero__description">{{ site.homepage.hero.description_html | safe }}</div>
            <div class="c-hero__btn">
              <a href="{{ site.homepage.hero.cta_button_link }}" class="cta-button c-button c-button--primary c-button--small">{{ site.homepage.hero.cta_button }}</a>
              <a class="works-button c-button c-button--secondary c-button--small" href="{{ site.homepage.hero.works_button_link }}">
                <span class="circle-bg"><i class="ion ion-md-arrow-down button-arrow"></i></span> {{ site.homepage.hero.works_button }}
              </a>
            </div>
          </div>

          <div class="c-hero__right">
            <div class="c-hero__image">
              <img loading="lazy" src="{{ site.homepage.hero.image }}" alt="{{ site.homepage.hero.image_alt }}">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section projects" id="projects">
  <div class="container">
    <div class="row">
      <div class="col col-12">
        <div class="contaniner__inner animate">
          <div class="section__info">
            <div class="section__head">
              <h2 class="section__title">{{ site.homepage.projectsSection.title }}</h2>
              <a class="section__link" href="{{ site.homepage.projectsSection.link_url }}">View all <i class="ion ion-md-arrow-forward"></i></a>
            </div>
            <div class="section__description">{{ site.homepage.projectsSection.description_html | safe }}</div>
          </div>

          <div class="row">
            {% for project in collections.projects %}
              {% if loop.index <= 6 %}
                {{ projectCard(project) }}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section testimonials animate">
  <div class="container">
    <div class="row">
      <div class="col col-12">
        <div class="section__info">
          <div class="section__head">
            <h2 class="section__title">{{ site.homepage.testimonialsSection.title }}</h2>
            <ul class="controls list-reset" id="customize-controls" aria-label="Slider Navigation" tabindex="0">
              <li class="prev" data-controls="prev" aria-controls="customize" tabindex="-1"><i class="ion ion-ios-arrow-back"></i></li>
              <li class="next" data-controls="next" aria-controls="customize" tabindex="-1"><i class="ion ion-ios-arrow-forward"></i></li>
            </ul>
          </div>
          <div class="section__description">{{ site.homepage.testimonialsSection.description_html | safe }}</div>
        </div>

        <div class="testimonials__slider my-slider">
          {% for t in site.testimonials %}
            {{ testimonialCard(t) }}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section blog">
  <div class="container">
    <div class="row">
      <div class="col col-12">
        <div class="contaniner__inner animate">
          <div class="section__info">
            <div class="section__head">
              <h2 class="section__title">{{ site.homepage.blogSection.title }}</h2>
              <a class="section__link" href="{{ site.homepage.blogSection.link_url }}">View all <i class="ion ion-md-arrow-forward"></i></a>
            </div>
            <div class="section__description">{{ site.homepage.blogSection.description_html | safe }}</div>
          </div>

          <div class="row">
            {% for post in collections.posts %}
              {% if loop.index <= 3 %}
                {{ blogCard(post) }}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{{ newsletter(site.newsletter) }}

<div class="c-contact-form" id="contact">
  <div class="container">
    <div class="row">
      <div class="col col-12">
        <div class="c-contact-form__form-box">
          <div class="c-contact-form__contact-head">
            <h2 class="c-contact-form__contact-title">{{ site.homepage.contactForm.form_title }}</h2>
            <p class="c-contact-form__contact-description">{{ site.homepage.contactForm.form_description }}</p>
          </div>
          <form class="c-contact-form__form" action="{{ site.homepage.contactForm.form_success_page }}" method="POST">
            <input type="hidden" name="_to" value="{{ site.homepage.contactForm.form_submission_email }}">
            <div class="c-contact-form__form-group">
              <label class="c-contact-form__form-label screen-reader-text" for="form-name">Your Name</label>
              <input class="c-contact-form__form-input" id="form-name" type="text" name="name" placeholder="Your name..." required>
            </div>
            <div class="c-contact-form__form-group">
              <label class="c-contact-form__form-label screen-reader-text" for="form-email">Your Email</label>
              <input class="c-contact-form__form-input" id="form-email" type="email" name="_replyto" placeholder="Your email..." required>
            </div>
            <div class="c-contact-form__form-group">
              <label class="c-contact-form__form-label screen-reader-text" for="form-text">Your Message</label>
              <textarea class="c-contact-form__form-input" id="form-text" name="text" rows="9" placeholder="Your message..." required></textarea>
            </div>
            <div class="c-contact-form__form-group c-contact-form__form-group--button">
              <button class="c-button c-button--primary c-button--large" type="submit">{{ site.homepage.contactForm.form_button_text }}</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
