{% if site.socialIcons and site.socialIcons.length %}
<div class="social">
  <ul class="social__list list-reset">
    {% for social_icon in site.socialIcons %}
    <li class="social__item">
      <a class="social__link" href="{{ social_icon.url }}" target="_blank" rel="noopener" aria-label="{{ social_icon.icon }} icon">
        <i class="ion ion-logo-{{ social_icon.icon | lower }}"></i>
      </a>
    </li>
    {% endfor %}
  </ul>
</div>
{% endif %}
