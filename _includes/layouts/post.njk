---
layout: layouts/base.njk
---
<div class="post-top">
  <div class="container">
    <div class="row">
      {% if image %}
      <div class="col col-6 col-d-12">
        <div class="post-image">
          <img loading="lazy" src="{{ image }}" alt="{{ title }}">
        </div>
      </div>
      {% endif %}

      <div class="col col-6 col-d-12">
        <div class="post__info">
          {% if tags and tags.length %}
          <div class="post-tags">
            {% for tag in tags %}
            <a href="/tags/{{ tag | slugify }}/" class="post-tags__tag">{{ tag }}</a>
            {% endfor %}
          </div>
          {% endif %}

          <h1 class="post__title">{{ title }}</h1>

          <div class="post__meta">
            <div class="post__author-image">
              <img loading="lazy" src="{{ author_image or site.authorImage }}" alt="{{ author or site.author }}">
            </div>

            <div class="post__meta-bottom">
              <div class="post__author">{{ author or site.author }}</div>
              <time class="post__date" datetime="{{ date | htmlDateString }}">{{ date | readableDate(site.dateFormat) }}</time>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="container animate">
  <article class="post">
    <div class="post__content">
      {{ content | safe }}
    </div>

    {% include "partials/share.njk" %}
  </article>
</div>

<div class="container">
  <div class="row">
    <div class="col col-10 col-d-12 push-d-0 push-1">
      {% include "partials/post-navigation.njk" %}
    </div>
  </div>
</div>

{% include "partials/disqus-comments.njk" %}
{% include "partials/related-posts.njk" %}

{% from "components.njk" import newsletter %}
{{ newsletter(site.newsletter) }}
