---
layout: layouts/base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
eleventyComputed:
  title: "{{ tag | title }}"
permalink: "/tags/{{ tag | slugify }}/index.html"
---
{% from "components.njk" import pageHeading, blogCard, newsletter %}
{{ pageHeading(tag | title) }}

<div class="container">
  <div class="row">
    <div class="col col-12">
      <div class="contaniner__inner animate">
        <div class="row">
          {% for post in collections.posts | postsWithTag(tag) %}
            {{ blogCard(post) }}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{{ newsletter(site.newsletter) }}
